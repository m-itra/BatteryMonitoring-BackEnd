# Local development values
# Used by local service launches and Infrastructure scripts like run_migrations.ps1.
USER_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/userdb
BATTERY_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/batterydb

USER_DB_HOST=localhost
USER_DB_PORT=5434
USER_DB_NAME=userdb
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres

BATTERY_DB_HOST=localhost
BATTERY_DB_PORT=5434
BATTERY_DB_NAME=batterydb
BATTERY_DB_USER=postgres
BATTERY_DB_PASSWORD=postgres

USER_SERVICE_URL=http://localhost:8001
PROCESSING_SERVICE_URL=http://localhost:8002
ANALYTICS_SERVICE_URL=http://localhost:8003
USER_SERVICE_GRPC_URL=localhost:50051
PROCESSING_SERVICE_GRPC_URL=localhost:50052

JWT_SECRET=my-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=720
AUTH_COOKIE_MAX_AGE_SECONDS=2592000
MIN_SESSION_DISCHARGE_PERCENT=5

# Docker Compose values
# Used only by Infrastructure/docker-compose.yml.
DOCKER_ENVIRONMENT=docker

DOCKER_USER_DB_NAME=userdb
DOCKER_USER_DB_USER=admin
DOCKER_USER_DB_PASSWORD=password
DOCKER_USER_DATABASE_URL=postgresql://admin:password@user-db:5432/userdb

DOCKER_BATTERY_DB_NAME=batterydb
DOCKER_BATTERY_DB_USER=admin
DOCKER_BATTERY_DB_PASSWORD=password
DOCKER_BATTERY_DATABASE_URL=postgresql://admin:password@battery-db:5432/batterydb

DOCKER_USER_SERVICE_URL=http://user-service:8001
DOCKER_PROCESSING_SERVICE_URL=http://processing-service:8002
DOCKER_ANALYTICS_SERVICE_URL=http://analytics-service:8003
DOCKER_USER_SERVICE_GRPC_URL=user-service:50051
DOCKER_PROCESSING_SERVICE_GRPC_URL=processing-service:50052

DOCKER_JWT_SECRET=my-secret-key-change-in-production
DOCKER_JWT_ALGORITHM=HS256
DOCKER_JWT_EXPIRATION_HOURS=720
DOCKER_AUTH_COOKIE_MAX_AGE_SECONDS=2592000
DOCKER_MIN_SESSION_DISCHARGE_PERCENT=5
